# Copy to .env for local development. Never commit the real .env.

# Option 1 — hosted Postgres (Neon). If set, this wins over the DB_* vars.
# This is the same value you give Fly with `fly secrets set DATABASE_URL=...`.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Option 2 — local Postgres (used when DATABASE_URL is unset).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=espresso
DB_USER=postgres
DB_PASSWORD=
