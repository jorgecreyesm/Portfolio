# Copy this file to .env and fill in your own values.
# .env is gitignored; never commit real keys.

# US Census Bureau API key (https://api.census.gov/data/key_signup.html)
CENSUS_API_KEY=your_census_key_here

# USDA NASS Quick Stats API key (https://quickstats.nass.usda.gov/api)
NASS_API_KEY=your_nass_key_here

# PostgreSQL connection.
#
# Option 1 -- hosted Postgres (Neon, Supabase, ...). If DATABASE_URL is set
# it wins over the DB_* parts below, and the pipeline will read and write
# that database instead of the local one. This is the same value that goes
# into the deployed app's Streamlit secrets.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Option 2 -- local development. Used when DATABASE_URL is unset.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cv_dashboard
DB_USER=postgres
DB_PASSWORD=your_password_here
